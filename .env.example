APP_NAME="GarmentsOS PRO"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database.sqlite
DB_FOREIGN_KEYS=true

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_ENABLED=false
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap2

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

SUBSCRIPTION_EXPIRE_DATE=2026-12-31
SUBSCRIPTION_MODE=demo

COMPANY_NAME="Client Company Name"
COMPANY_OWNER="Client Owner Name"
COMPANY_LOGO=garmentsos_pro_logo.png
COMPANY_LOGO_TEXT=
COMPANY_PHONE="021-12345678 | 0321-98765432"
COMPANY_DATE="01-01-2020"
COMPANY_CITY="Client City"
COMPANY_ADDRESS="Client Address"
COMPANY_LOGO_SVG_PATH=images/garmentsos_pro_logo.svg

INSTALLATION_MODE=local_lan
FIRST_RUN_SETUP_FORCE=false

BACKUP_RESTORE_ENABLED=true

APP_VERSION=1.8.84
GARMENTSOS_IMAGE=sparkpair/garmentsos-pro:1.8.84

UPDATER_ENABLED=true
UPDATE_FEED_URL=https://www.sparkpair.dev/api/updates/garmentsos-pro/stable/latest.json
UPDATE_FALLBACK_FEED_URL=https://github.com/Spark-Pair/garmentsos-pro/releases/download/latest-stable/latest.json
UPDATE_FEED_TIMEOUT=8
UPDATE_APP_SHELL_FEED_CACHE_SECONDS=0
UPDATE_CHANNEL=stable
UPDATE_LAUNCHER_PROTOCOL=garmentsos
UPDATE_REQUEST_TTL_MINUTES=10
UPDATE_LOCK_TTL_MINUTES=30

LICENSE_ENFORCEMENT_ENABLED=true
LICENSE_ENABLED=true
LICENSE_AUTO_REGISTER=true
LICENSE_GRACE_DAYS=7
LICENSE_CHECK_URL=https://www.sparkpair.dev/api/licenses/verify
LICENSE_REGISTER_URL=https://www.sparkpair.dev/api/licenses/register-install
LICENSE_REQUEST_DEMO_URL=https://www.sparkpair.dev/api/licenses/request-demo
LICENSE_DEVELOPMENT_BYPASS=false

LICENSE_SERVER_URL=
LICENSE_PUBLIC_KEY=
LICENSE_OFFLINE_GRACE_DAYS=7
