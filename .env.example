APP_NAME=garmentsos-pro
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://192.168.100.11:8000

APP_CLIENT=default
APP_CLIENT_NAME="GarmentsOS PRO"
APP_VERSION=0.0.0-local
APP_UPDATE_CHANNEL=stable

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
DB_DATABASE=/absolute/path/to/database.sqlite
DB_FOREIGN_KEYS=true

BACKUP_TEMP_PATH=
BACKUP_MANUAL_PATH=
BACKUP_AUTOMATIC_PATH=
BACKUP_TEMP_RETENTION_MINUTES=120

BROADCAST_DRIVER=pusher
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=192.168.1.110

REDIS_HOST=192.168.1.110
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=ap2

VITE_APP_NAME="${APP_NAME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

PUSHER_ENABLED=true

SUBSCRIPTION_EXPIRE_DATE=2025-12-01
SUBSCRIPTION_MODE=demo   # demo OR paid

COMPANY_NAME='Client Company Name'
COMPANY_OWNER='Client Owner Name'
COMPANY_LOGO='garmentsos_pro_logo.png'
COMPANY_LOGO_TEXT='GarmentsOS PRO'
COMPANY_PHONE='021-12345678 | 0321-98765432'
COMPANY_DATE='Client Company registration date 01-01-2020'
COMPANY_CITY='Client City'
COMPANY_ADDRESS='Client Address, Street, Area'
COMPANY_LOGO_SVG_PATH=images/garmentsos_pro_logo.svg
