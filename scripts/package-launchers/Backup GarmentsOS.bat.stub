@echo off
setlocal
title Backup GarmentsOS PRO
set "PACKAGE_ROOT=%~dp0"

echo Creating GarmentsOS PRO backup...
echo This may take a few minutes.
echo.

powershell -NoProfile -ExecutionPolicy Bypass -File "%PACKAGE_ROOT%scripts\windows-docker-backup.ps1" -InstallDir "C:\SparkPair\GarmentsOS"
if errorlevel 1 (
    echo.
    echo Backup did not complete. Please check the message above.
    pause
    exit /b 1
)

echo.
echo Backup complete.
pause
exit /b 0
