@echo off
setlocal
title Stop GarmentsOS PRO
set "PACKAGE_ROOT=%~dp0"

echo Stopping GarmentsOS PRO...

call "%PACKAGE_ROOT%scripts\stop.bat"
if errorlevel 1 (
    echo.
    echo GarmentsOS PRO could not be stopped. Please make sure Docker Desktop is running.
    pause
    exit /b 1
)

echo GarmentsOS PRO stopped.
exit /b 0
