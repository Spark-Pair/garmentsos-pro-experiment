{
  "schema_version": 1,
  "strategy": {
    "mode": "allowlist",
    "exclude_wins": true,
    "follow_symlinks": false,
    "allow_absolute_archive_paths": false,
    "allow_parent_traversal": false
  },
  "include_paths": [
    "app/**",
    "bootstrap/app.php",
    "config/**",
    "database/migrations/**",
    "resources/views/**",
    "routes/**",
    "public/build/**",
    "public/js/**",
    "public/images/**",
    "public/.htaccess",
    "public/index.php",
    "public/favicon.ico",
    "public/manifest.json",
    "public/service-worker.js",
    "public/offline.html",
    "public/robots.txt",
    "public/jquery.js",
    "public/calibri-regular.ttf",
    "vendor/**",
    "artisan",
    "composer.json",
    "composer.lock"
  ],
  "generated_paths": [
    "bootstrap/cache/packages.php",
    "bootstrap/cache/services.php",
    "release-info.json"
  ],
  "create_empty_directories": [
    "bootstrap/cache",
    "storage/framework/cache/data",
    "storage/framework/sessions",
    "storage/framework/views",
    "storage/logs"
  ],
  "exclude_paths": [
    ".git",
    ".git/**",
    ".github",
    ".github/**",
    ".fleet",
    ".fleet/**",
    ".idea",
    ".idea/**",
    ".vscode",
    ".vscode/**",
    ".env",
    ".env.*",
    "auth.json",
    "database/*.sqlite",
    "database/*.sqlite-*",
    "database/*.sqlite-wal",
    "database/*.sqlite-shm",
    "database/**/*.sqlite",
    "database/**/*.sqlite-*",
    "storage/app",
    "storage/app/**",
    "storage/logs/*",
    "storage/logs/**",
    "storage/framework/cache/*",
    "storage/framework/cache/**",
    "storage/framework/sessions/*",
    "storage/framework/sessions/**",
    "storage/framework/views/*",
    "storage/framework/views/**",
    "public/storage",
    "public/storage/**",
    "public/uploads",
    "public/uploads/**",
    "public/hot",
    "node_modules",
    "node_modules/**",
    "tests",
    "tests/**",
    "docs",
    "docs/**",
    "scripts",
    "scripts/**",
    "backups",
    "backups/**",
    "logs",
    "logs/**",
    "runtime",
    "runtime/**",
    "release-artifacts",
    "release-artifacts/**",
    "database/factories",
    "database/factories/**",
    "database/seeders",
    "database/seeders/**",
    ".phpunit.cache",
    ".phpunit.result.cache",
    "phpunit.xml",
    "package.json",
    "package-lock.json",
    "vite.config.js",
    "postcss.config.js",
    "tailwind.config.js",
    "README.md",
    "REPORT_RESTRICTIONS.md",
    "CHANGELOG.md",
    "*.bat",
    "*.vbs",
    "supplier temps.js",
    "npm-debug.log",
    "yarn-error.log",
    "Homestead.json",
    "Homestead.yaml"
  ],
  "prohibited_patterns": {
    "path_globs": [
      "**/.env",
      "**/.env.*",
      "**/.git/**",
      "**/.github/**",
      "**/auth.json",
      "**/*.sqlite",
      "**/*.sqlite-wal",
      "**/*.sqlite-shm",
      "**/*.sqlite-*",
      "**/*.db",
      "**/*.dump",
      "**/*.sql.gz",
      "**/*.bak",
      "**/*.backup",
      "**/*.pem",
      "**/*.key",
      "**/*.pfx",
      "**/*.p12",
      "**/id_rsa",
      "**/id_ed25519",
      "**/*private-key*",
      "**/*private_key*",
      "**/*developer-note*",
      "**/*developer_note*",
      "**/*client-override*",
      "**/*client_override*"
    ],
    "archive_entry_regex": [
      "^[A-Za-z]:[\\\\/]",
      "^/",
      "(^|[\\\\/])\\.\\.([\\\\/]|$)"
    ],
    "secret_content_regex": [
      "(?i)ghp_[a-z0-9]{20,}",
      "(?i)github[_-]?token\\s*[:=]",
      "(?i)(api[_-]?key|client[_-]?secret|access[_-]?token)\\s*[:=]",
      "-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----"
    ],
    "forbidden_client_content": [
      "unapproved client overlays",
      "branding or identity files belonging to another client",
      "real client environment files",
      "client databases, uploads, logs, backups, or runtime data"
    ]
  },
  "required_files": [
    "artisan",
    "composer.json",
    "composer.lock",
    "bootstrap/app.php",
    "bootstrap/cache/packages.php",
    "bootstrap/cache/services.php",
    "config/app.php",
    "config/client.php",
    "routes/web.php",
    "public/index.php",
    "public/build/manifest.json",
    "public/manifest.json",
    "public/service-worker.js",
    "public/offline.html",
    "vendor/autoload.php",
    "release-info.json"
  ],
  "required_directories": [
    "app",
    "bootstrap/cache",
    "config",
    "database/migrations",
    "public/build",
    "public/images",
    "public/js",
    "resources/views",
    "routes",
    "storage/framework/cache/data",
    "storage/framework/sessions",
    "storage/framework/views",
    "storage/logs",
    "vendor"
  ],
  "required_validations": [
    "public/build/manifest.json is valid JSON",
    "every Vite manifest file entry exists in public/build",
    "vendor/autoload.php loads successfully",
    "production vendor contains no Composer development packages",
    "staged files are all matched by include_paths",
    "no staged file matches exclude_paths or prohibited_patterns",
    "archive entries are relative and contain no parent traversal",
    "archive contains no symbolic links, junctions, or reparse points",
    "embedded release-info.json matches requested client, version, and channel",
    "detached manifest file count matches archive inventory",
    "detached SHA-256 matches the final ZIP"
  ],
  "manifest_fields": {
    "embedded_release_info": [
      "schema_version",
      "app.name",
      "app.version",
      "target.client_id",
      "target.client_name",
      "target.channel",
      "build.built_at",
      "build.source_commit",
      "database.migrations_included",
      "database.migration_count",
      "database.migrations"
    ],
    "detached_release_manifest": [
      "schema_version",
      "app.name",
      "app.version",
      "target.client_id",
      "target.client_name",
      "target.channel",
      "build.built_at",
      "build.source_commit",
      "artifact.filename",
      "artifact.sha256",
      "artifact.size_bytes",
      "artifact.included_files_count",
      "database.migrations_included",
      "database.migration_count",
      "database.migrations"
    ]
  },
  "client_package_rules": {
    "require_explicit_client_id": true,
    "require_explicit_client_name": true,
    "require_explicit_version": true,
    "require_explicit_channel": true,
    "allow_only_declared_overlay": true,
    "reject_cross_client_content": true,
    "include_real_client_environment": false,
    "include_client_runtime_data": false
  }
}
